      "source": [
        "#NOW WE SMOOTH"
      ],
      "metadata": {
        "id": "oyy4v8-Rvauk"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def window_smooth(states, window, thr0=0.50, thr12=0.80): #if we find a window of 50% ibd0, make it ibd0, 80% for ibd1 and 2\n",
        "    s = np.asarray(states, dtype=int)\n",
        "    out = s.copy()\n",
        "    n = len(s)\n",
        "\n",
        "    for i in range(0, n - window + 1):\n",
        "\n",
        "        w = s[i:i+window]\n",
        "\n",
        "        f0 = np.mean(w == 0)\n",
        "        f1 = np.mean(w == 1)\n",
        "        f2 = np.mean(w == 2)\n",
        "\n",
        "        if f0 > thr0:\n",
        "\n",
        "            out[i:i+window] = 0\n",
        "            continue\n",
        "\n",
        "        if f1 >= thr12:\n",
        "\n",
        "            out[i:i+window] = 1\n",
        "            continue\n",
        "\n",
        "        if f2 >= thr12:\n",
        "\n",
        "            out[i:i+window] = 2\n",
        "            continue\n",
        "    return out\n",
        "\n",
        "\n",
        "\n",
        "smoothed = window_smooth(states, 10, 0.5, 0.8)\n",
        "smoothed = np.asarray(smoothed, dtype=int)\n",
        "\n",
        "# map from blocks back to BPs\n",
        "\n",
        "df2 = df.copy().reset_index(drop=True)\n",
        "df2[\"snp_idx\"] = np.arange(len(df2))\n",
        "df2[\"block\"] = (df2[\"snp_idx\"] // BLOCK_SIZE).astype(int)\n",
        "df2[\"ibd_state\"] = smoothed[df2[\"block\"].values]\n",
        "\n",
        "blocks = df2.groupby(\"block\").agg(start_pos=(\"pos\", \"first\"), end_pos=(\"pos\", \"last\"),ibd_state=(\"ibd_state\", \"first\")).reset_index()\n",
        "blocks[\"bp_span\"] = blocks[\"end_pos\"] - blocks[\"start_pos\"]\n",
        "\n",
        "# %s of each IBD\n",
        "bp_by_state = blocks.groupby(\"ibd_state\")[\"bp_span\"].sum()\n",
        "bp_total = bp_by_state.sum()\n",
        "pct_by_state = (100 * bp_by_state) / bp_total\n",
        "\n",
        "# final graph (AI Assisted Graph Generation) (helpful for it to provide the syntax)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(16, 2.2))\n",
        "colors = {0: \"purple\", 1: \"turquoise\", 2: \"yellow\"}\n",
        "\n",
        "for _, r in blocks.iterrows():\n",
        "    x0 = float(r[\"start_pos\"])\n",
        "    w = float(r[\"bp_span\"])\n",
        "    if w < 1:\n",
        "        w = 1\n",
        "    ax.broken_barh([(x0, w)], (0, 1), facecolors=[colors[int(r[\"ibd_state\"])]])\n",
        "\n",
        "ax.set_yticks([])\n",
        "ax.set_xlabel(\"Position (bp)\")\n",
        "ax.set_title(f\"{sample1} vs {sample2}: IBD states by {BLOCK_SIZE}-SNP blocks\")\n",
        "\n",
        "legend_elements = [\n",
        "    Patch(facecolor=\"purple\", label=\"IBD0\"),\n",
        "    Patch(facecolor=\"turquoise\", label=\"IBD1\"),\n",
        "    Patch(facecolor=\"yellow\", label=\"IBD2\"),\n",
        "]\n",
        "ax.legend(handles=legend_elements, loc=\"upper right\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"Percent of chromosome in each IBD:\")\n",
        "for k in (0, 1, 2):\n",
        "    pct = float(pct_by_state.get(k, 0.0))\n",
        "    print(f\"  IBD{k}: {pct:.2f}%\")"
      ],
